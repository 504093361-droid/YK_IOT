<UserControl
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:models="clr-namespace:Collector.Contracts.Enums;assembly=Collector.Contracts"
    x:Class="Collector.UI.Views.Page1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Collector.UI.ViewModel"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors" 
    d:DataContext="{d:DesignInstance Type=vm:Page1ViewModel}"
    d:DesignHeight="720"
    d:DesignWidth="1400"
    Background="#F3F4F6"
    mc:Ignorable="d">

    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding PageLoadedCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>

    <UserControl.Resources>
        <ObjectDataProvider x:Key="ProtocolEnumProvider" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ProtocolTypeEnum" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="DataTypeEnumProvider" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:DataTypeEnum" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="DataFormatEnumProvider" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:DataFormatEnum" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style x:Key="GridTextBlockStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="4,0,4,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="GridTextBoxStyle" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="2,0,2,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="2,-1,2,-1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="#F2F6FC" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#DCDFE6" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal" Cursor="">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="数据采集配置中心" FontSize="16" FontWeight="Bold" Foreground="#303133" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock Text="Youkai_Scada_Collector" FontSize="12" FontWeight="Bold" Foreground="#909399" VerticalAlignment="Center" Margin="0,0,20,0"/>
                </StackPanel>
                <Button Content="➕ 新增设备" Command="{Binding AddDeviceCommand}" Width="100" Height="28" FontSize="12" Margin="0,0,10,0" Background="#409EFF" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="📂 读取配置" Command="{Binding LoadConfigCommand}" Width="100" Height="28" FontSize="12" Margin="0,0,10,0" Background="#909399" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="💾 保存配置" Command="{Binding SaveConfigCommand}" Width="100" Height="28" FontSize="12" Margin="0,0,20,0" Background="#E6A23C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="📥 Excel导入" Command="{Binding ImportExcelCommand}" Width="90" Height="28" FontSize="12" Margin="0,0,5,0" Background="#E6A23C" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="按模板导入设备与点位全量配置"/>
                <Button Content="📄 下模板" Command="{Binding DownloadTemplateCommand}" Width="80" Height="28" FontSize="12" Margin="0,0,15,0" Background="#909399" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                <Button Content="⏹ 停止采集" Command="{Binding StopCollectCommand}" Width="100" Height="28" FontSize="12" Margin="0,0,10,0" Background="#F56C6C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                <Button Content="▶ 启动/更新" Command="{Binding StartCollectCommand}" Width="110" Height="28" FontSize="12" Background="#67C23A" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="设备列表" FontSize="11" FontWeight="Bold" Foreground="#606266" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="车间筛选：" FontSize="11" Foreground="#909399" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox ItemsSource="{Binding AvailableWorkshops}" 
                  SelectedItem="{Binding SelectedWorkshopFilter}" 
                  Width="100" Height="22" FontSize="11" Padding="5,0"
                  BorderBrush="#DCDFE6" Background="#F4F4F5"/>
                    </StackPanel>
                </Grid>

                <DataGrid Grid.Row="1" 
                          FrozenColumnCount="2"
                          ItemsSource="{Binding FilteredDeviceConfigs}" 
                          SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                          AutoGenerateColumns="False" CanUserAddRows="False" 
                          RowDetailsVisibilityMode="VisibleWhenSelected"
                          Background="White" RowHeight="30" ColumnHeaderHeight="32" FontSize="12"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EBEEF5"
                          BorderThickness="1" BorderBrush="#E4E7ED"
                          HeadersVisibility="Column" Cursor="">

                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border Background="#F4F8FE" Padding="25,12" BorderThickness="0,1,0,1" BorderBrush="#DCDFE6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ProtocolType}" Value="{x:Static models:ProtocolTypeEnum.ModbusTCP}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔧 Modbus 专属高级配置：" FontWeight="Bold" Foreground="#409EFF" VerticalAlignment="Center" Margin="0,0,20,0"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,25,0">
                                        <TextBlock Text="协议字节序:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#606266"/>
                                        <ComboBox ItemsSource="{Binding Source={StaticResource DataFormatEnumProvider}}"
                                                  SelectedItem="{Binding DataFormat, UpdateSourceTrigger=PropertyChanged}"
                                                  Width="90" Height="26" FontSize="12" Background="White" BorderBrush="#DCDFE6"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                        <CheckBox IsChecked="{Binding IsAddressStartWithZero, UpdateSourceTrigger=PropertyChanged}"
                                                  Content="寄存器地址从 0 开始 (0-Based)" FontSize="12" Foreground="#606266" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </WrapPanel>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="设备ID" Binding="{Binding DeviceId}" Width="110" IsReadOnly="True" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="设备名称" Binding="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}" Width="150" 
                                            ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>
                        <DataGridTextColumn Header="所属车间" Binding="{Binding Workshop, UpdateSourceTrigger=PropertyChanged}" Width="100" 
                            ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>

                        <DataGridComboBoxColumn Header="协议类型" 
                                                SelectedItemBinding="{Binding ProtocolType, UpdateSourceTrigger=PropertyChanged}" 
                                                ItemsSource="{Binding Source={StaticResource ProtocolEnumProvider}}" 
                                                Width="110" />

                        <DataGridTextColumn Header="IP地址" Binding="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" Width="140" 
                                            ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>
                        <DataGridTextColumn Header="端口" Binding="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Width="80" 
                                            ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>
                        <DataGridTextColumn Header="站号" Binding="{Binding Station, UpdateSourceTrigger=PropertyChanged}" Width="50" 
                     ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>
                        <DataGridTextColumn Header="怠速扫描(ms)" Binding="{Binding ScanIntervalMs, UpdateSourceTrigger=PropertyChanged}" Width="90" 
                                            ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>

                        <DataGridTemplateColumn Header="操作" Width="80"  >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="删除" FontSize="12"  Command="{Binding DataContext.DeleteDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Foreground="#F56C6C" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="运行状态" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,2" Margin="4,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F4F4F5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="1">
                                                        <Setter Property="Background" Value="#F0F9EB"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="-1">
                                                        <Setter Property="Background" Value="#FEF0F0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock Text="{Binding WorkerStatus}" FontSize="11" FontWeight="SemiBold" 
                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding WorkerStatus}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#909399"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusCode}" Value="1">
                                                            <Setter Property="Foreground" Value="#67C23A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusCode}" Value="-1">
                                                            <Setter Property="Foreground" Value="#F56C6C"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,10" IsEnabled="{Binding IsDeviceSelected}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#ECF5FF" BorderBrush="#D9ECFF" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,10,0">
                    <TextBlock Text="{Binding SelectedDevice.DeviceName, StringFormat='当前配置点位归属: {0}'}" Foreground="#409EFF" FontSize="13" FontWeight="SemiBold"/>
                </Border>
                <Button Content="➕ 添加采集点位" FontSize="12" Command="{Binding AddPointCommand}" Width="120" Height="28" Background="#409EFF" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="💡 提示：点击选中具体点位，即可展开底层高级配置面板 (死区、公式等)。" Foreground="#909399" FontSize="12" VerticalAlignment="Center" Margin="15,0,0,0"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0" IsEnabled="{Binding IsDeviceSelected}">

            <DataGrid ItemsSource="{Binding SelectedDevice.Points}" 
                      FrozenColumnCount="2"
                      AutoGenerateColumns="False" CanUserAddRows="False" 
                      RowDetailsVisibilityMode="VisibleWhenSelected"
                      Background="White" RowHeight="30" ColumnHeaderHeight="32" FontSize="12"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EBEEF5"
                      BorderThickness="1" BorderBrush="#E4E7ED"
                      HeadersVisibility="Column">

                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <Border Background="#F4F8FE" Padding="35,12" BorderThickness="0,1,0,1" BorderBrush="#DCDFE6">
                            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⚙️ 数据处理参数：" FontWeight="Bold" Foreground="#67C23A" VerticalAlignment="Center" Margin="0,0,20,0"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0" ToolTip="仅字符串类型有效">
                                    <TextBlock Text="提取长度:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#606266"/>
                                    <TextBox Text="{Binding Length, UpdateSourceTrigger=PropertyChanged}" Width="50" Height="24" Padding="4,0" VerticalContentAlignment="Center" BorderThickness="1" BorderBrush="#DCDFE6">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Setter Property="Background" Value="#E4E7ED"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataType}" Value="{x:Static models:DataTypeEnum.String}">
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                        <Setter Property="Background" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                    <TextBlock Text="比例(k):" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#606266"/>
                                    <TextBox Text="{Binding Multiplier, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="24" Background="White" BorderBrush="#DCDFE6" BorderThickness="1" Padding="4,0" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                    <TextBlock Text="偏移(b):" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#606266"/>
                                    <TextBox Text="{Binding Offset, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="24" Background="White" BorderBrush="#DCDFE6" BorderThickness="1" Padding="4,0" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                    <TextBlock Text="数学公式:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#606266"/>
                                    <TextBox Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}" Width="160" Height="24" Background="White" BorderBrush="#DCDFE6" BorderThickness="1" Padding="4,0" VerticalContentAlignment="Center" ToolTip="例如: x * 2 + Sin(x)"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0" ToolTip="过滤阈值，数值变化大于该值才上报">
                                    <TextBlock Text="死区拦截(±):" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#E6A23C"/>
                                    <TextBox Text="{Binding Deadband, UpdateSourceTrigger=PropertyChanged}" Width="50" Height="24" Background="White" BorderBrush="#DCDFE6" BorderThickness="1" Padding="4,0" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="点位ID" Binding="{Binding PointId}" Width="90" IsReadOnly="True" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                    <DataGridTextColumn Header="点位名称" Binding="{Binding PointName, UpdateSourceTrigger=PropertyChanged}" Width="150" 
                                        ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>
                    <DataGridTextColumn Header="寄存器地址" Binding="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Width="130" 
                                        ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>

                    <DataGridComboBoxColumn Header="数据类型" 
                                            SelectedItemBinding="{Binding DataType, UpdateSourceTrigger=PropertyChanged}" 
                                            ItemsSource="{Binding Source={StaticResource DataTypeEnumProvider}}" 
                                            Width="90" />

                    <DataGridTextColumn Header="采集周期(ms)" Binding="{Binding ScanIntervalMs, UpdateSourceTrigger=PropertyChanged}" Width="100"
                    ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="ToolTip" Value="必须大于等于上级设备的怠速周期"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="底层原始值" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RawValue}" Foreground="#909399" FontSize="12" VerticalAlignment="Center" Margin="6,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="熟肉当前值" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ProcessedValue}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#409EFF"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="#F56C6C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="最后更新" Binding="{Binding LastUpdateTime, StringFormat={}{0:HH:mm:ss.fff}}" Width="120" IsReadOnly="True" ElementStyle="{StaticResource GridTextBlockStyle}"/>

                    <DataGridTemplateColumn Header="操作" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="移除" FontSize="12" Command="{Binding DataContext.DeletePointCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Foreground="#F56C6C" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="异常实时诊断" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#F56C6C" FontSize="11" VerticalAlignment="Center" Margin="4,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding ErrorMessage}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>