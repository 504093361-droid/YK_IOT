<UserControl
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:models="clr-namespace:Collector.Contracts.Enums;assembly=Collector.Contracts"
    x:Class="Collector.UI.Views.Page1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Collector.UI.ViewModel"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    d:DataContext="{d:DesignInstance Type=vm:Page1ViewModel}"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    Background="#F3F4F6"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ObjectDataProvider x:Key="ProtocolEnumProvider" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ProtocolTypeEnum" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="DataTypeEnumProvider" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:DataTypeEnum" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <Style x:Key="GridTextBlockStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="6,0,6,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="GridTextBoxStyle" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="3,0,3,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="3,-2,3,-2" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#F2F6FC" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="#DCDFE6" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal">
             
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="数据采集配置中心" FontSize="20" FontWeight="Bold" Foreground="#303133" VerticalAlignment="Center" Margin="0,0,30,0"/>
                    <TextBlock Text="Youkai_Scada_Collector" FontSize="14" FontWeight="Bold" Foreground="#303133" VerticalAlignment="Center" Margin="0,0,30,0"/>
                </StackPanel>
                <Button Content="➕ 新增设备" Command="{Binding AddDeviceCommand}" Width="120" Height="36" Margin="0,0,15,0" Background="#409EFF" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="📂 读取配置" Command="{Binding LoadConfigCommand}" Width="120" Height="36" Margin="0,0,15,0" Background="#909399" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="💾 保存配置" Command="{Binding SaveConfigCommand}" Width="120" Height="36" Margin="0,0,30,0" Background="#E6A23C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="▶ 启动采集引擎" Command="{Binding StartCollectCommand}" Width="150" Height="36" Background="#67C23A" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="设备列表 (选中下方展开点位)" FontSize="16" FontWeight="SemiBold" Foreground="#606266" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding DeviceConfigs}" 
                          SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                          AutoGenerateColumns="False" CanUserAddRows="False" 
                          Background="White" RowHeight="40" ColumnHeaderHeight="45"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EBEEF5"
                          BorderThickness="1" BorderBrush="#E4E7ED"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="设备ID" Binding="{Binding DeviceId}" Width="120" IsReadOnly="True" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                        <DataGridTextColumn Header="设备名称" Binding="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}" Width="180" 
                                            ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>

                        <DataGridComboBoxColumn Header="协议类型" 
                        SelectedItemBinding="{Binding ProtocolType, UpdateSourceTrigger=PropertyChanged}" 
                        ItemsSource="{Binding Source={StaticResource ProtocolEnumProvider}}" 
                        Width="140" />

                        <DataGridTextColumn Header="IP地址" Binding="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" Width="160" 
                                            ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>
                        <DataGridTextColumn Header="端口" Binding="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Width="100" 
                                            ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>
                        <DataGridTextColumn Header="扫描周期(ms)" Binding="{Binding ScanIntervalMs, UpdateSourceTrigger=PropertyChanged}" Width="120" 
                                            ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>

                        <DataGridTemplateColumn Header="操作" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="删除" Command="{Binding DataContext.DeleteDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Foreground="#F56C6C" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,15" IsEnabled="{Binding IsDeviceSelected}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#ECF5FF" BorderBrush="#D9ECFF" BorderThickness="1" CornerRadius="4" Padding="10,5" Margin="0,0,15,0">
                    <TextBlock Text="{Binding SelectedDevice.DeviceName, StringFormat='当前配置点位归属: {0}'}" Foreground="#409EFF" FontSize="15" FontWeight="SemiBold"/>
                </Border>
                <Button Content="➕ 添加采集点位" Command="{Binding AddPointCommand}" Width="140" Height="34" Background="#409EFF" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0" IsEnabled="{Binding IsDeviceSelected}">
            <DataGrid ItemsSource="{Binding SelectedDevice.Points}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" 
                      Background="White" RowHeight="40" ColumnHeaderHeight="40"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EBEEF5"
                      BorderThickness="1" BorderBrush="#E4E7ED"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="点位ID" Binding="{Binding PointId}" Width="120" IsReadOnly="True" ElementStyle="{StaticResource GridTextBlockStyle}"/>
                    <DataGridTextColumn Header="点位名称" Binding="{Binding PointName, UpdateSourceTrigger=PropertyChanged}" Width="180" 
                                        ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>
                    <DataGridTextColumn Header="寄存器地址" Binding="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Width="160" 
                                        ElementStyle="{StaticResource GridTextBlockStyle}" EditingElementStyle="{StaticResource GridTextBoxStyle}"/>

                    <DataGridComboBoxColumn Header="数据类型" 
                        SelectedItemBinding="{Binding DataType, UpdateSourceTrigger=PropertyChanged}" 
                        ItemsSource="{Binding Source={StaticResource DataTypeEnumProvider}}" 
                        Width="140" />

                    <DataGridTemplateColumn Header="操作" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="移除" Command="{Binding DataContext.DeletePointCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Foreground="#F56C6C" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>