<hc:Window
    x:Class="Collector.UI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Collector.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Collector.UI.Views"
    xmlns:vm="clr-namespace:Collector.UI.ViewModel"
    Title="{Binding Message}"
    Width="1280"
    Height="720"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    Background="Gray"
    MouseLeftButtonDown="Window_MouseLeftButtonDown"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">




    <TabControl
        BorderThickness="0"
        ItemsSource="{Binding ViewModels}"
        SelectedIndex="{Binding Index}"
        TabStripPlacement="Top">

        <TabControl.ItemContainerStyle>
            <Style TargetType="TabItem">
                <Setter Property="Visibility" Value="Collapsed" />
            </Style>
        </TabControl.ItemContainerStyle>


        <TabControl.Resources>
            <DataTemplate DataType="{x:Type vm:Page1ViewModel}">
                <views:Page1 />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:Page2ViewModel}">
                <views:Page2 />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:Page3ViewModel}">
                <views:Page3 />
            </DataTemplate>
        </TabControl.Resources>

    </TabControl>





</hc:Window>
